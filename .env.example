# Crucible — Environment Variables
# Copy to .env and fill in real values before running anything.

# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub ─────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=your_webhook_secret   # must match your repo's webhook settings
GITHUB_OWNER=your_org_or_username
GITHUB_REPO=your_repo_name

# ── UiPath Test Cloud ──────────────────────────────────────────────────────
TC_BASE_URL=https://cloud.uipath.com/{org}/{tenant}
TC_TOKEN=your_tc_bearer_token
TC_PROJECT_ID=your_project_id

# ── UiPath Maestro (optional) ──────────────────────────────────────────────
# Pipeline skips Maestro gracefully if these are unset.
MAESTRO_BASE_URL=https://cloud.uipath.com/{org}/{tenant}/orchestrator_
MAESTRO_TOKEN=your_maestro_token

# ── Development flags ──────────────────────────────────────────────────────
# Set TC_DRY_RUN=true to stub tc_pass_rate=0.78 — no TC API calls made.
# Useful for iterating on agents and confidence score without burning quota.
TC_DRY_RUN=false

# SQLite path shared between FastAPI webhook server and Streamlit dashboard.
STATE_DB=/tmp/crucible_state.db
